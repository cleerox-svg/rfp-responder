# NaughtRFP — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The app reads .env on startup and writes these values into the local
# SQLite database — no UI configuration needed.
#
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Okta LiteLLM proxy URL (internal — use https://llm.atko.ai for Okta employees)
LITELLM_BASE_URL=https://llm.atko.ai

# Your LiteLLM virtual API key (sk-... from https://llm.atko.ai/ui/api-keys/)
LITELLM_API_KEY=sk-your-key-here

# ── Optional: Okta Authentication (leave blank to run unauthenticated) ────────
#
# NaughtRFP supports Okta OIDC auth (Authorization Code + PKCE).
# Authentication is DISABLED by default so judges can access the app without
# an Okta account. To enable for production, fill in the values below and
# set okta_auth_enabled=true in the Settings UI.

# OKTA_DOMAIN=https://your-org.okta.com
# OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxxxx
# OKTA_REDIRECT_URI=http://localhost:5000/auth/callback

# ── Optional: Flask ───────────────────────────────────────────────────────────
# FLASK_SECRET_KEY=change-this-in-production
